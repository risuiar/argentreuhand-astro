---
import Layout from '../../layouts/Layout.astro';
---
<Layout lang="de" currentPath={Astro.url.pathname}>
  <div class="container mx-auto p-4">
    <section class="py-8 text-center">
      <h1 class="text-3xl font-bold mb-6">Beratung Buchen</h1>
      <p class="mb-4">Vereinbaren Sie jetzt ein unverbindliches Beratungsgespräch mit unseren Experten!</p>
      <p class="mb-2">Telefon: +41 076 510 03 80</p>
      <p class="mb-6">E-Mail: info@argentatreuhand.com</p>
      <form class="max-w-md mx-auto bg-gray-50 p-6 rounded-lg mt-8">
        <div class="mb-4">
          <label class="block mb-1 font-semibold">Name</label>
          <input type="text" class="w-full border rounded p-2" placeholder="Ihr Name" />
        </div>
        <div class="mb-4">
          <label class="block mb-1 font-semibold">E-Mail</label>
          <input type="email" class="w-full border rounded p-2" placeholder="Ihre E-Mail" />
        </div>
        <div class="mb-4">
          <label class="block mb-1 font-semibold">Nachricht</label>
          <textarea class="w-full border rounded p-2" placeholder="Ihre Nachricht"></textarea>
        </div>
        <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded">Absenden</button>
      </form>
    </section>
  </div>
</Layout>
