---
import Layout from '../../layouts/Layout.astro';
---
<Layout lang="es" currentPath={Astro.url.pathname}>
  <div class="container mx-auto p-4">
    <section class="py-8 text-center">
      <h1 class="text-3xl font-bold mb-6">Reservar Consulta</h1>
      <p class="mb-4">¡Reserve ahora una consulta sin compromiso con nuestros expertos!</p>
      <p class="mb-2">Teléfono: +41 076 510 03 80</p>
      <p class="mb-6">E-mail: info@argentatreuhand.com</p>
      <form class="max-w-md mx-auto bg-gray-50 p-6 rounded-lg mt-8">
        <div class="mb-4">
          <label class="block mb-1 font-semibold">Nombre</label>
          <input type="text" class="w-full border rounded p-2" placeholder="Su nombre" />
        </div>
        <div class="mb-4">
          <label class="block mb-1 font-semibold">E-mail</label>
          <input type="email" class="w-full border rounded p-2" placeholder="Su e-mail" />
        </div>
        <div class="mb-4">
          <label class="block mb-1 font-semibold">Mensaje</label>
          <textarea class="w-full border rounded p-2" placeholder="Su mensaje"></textarea>
        </div>
        <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded">Enviar</button>
      </form>
    </section>
  </div>
</Layout>
